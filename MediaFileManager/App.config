<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2"/>
  </startup>
  <appSettings>
    <!-- 默认扫描目录 -->
    <add key="DefaultScanPath" value="C:\"/>
    <!-- 默认同步目标目录 -->
    <add key="DefaultSyncTarget" value="D:\Backup"/>
    <!-- 支持的媒体文件扩展名 -->
    <add key="MediaExtensions" value="*.mp3;*.wav;*.wma;*.mp4;*.avi;*.wmv;*.mkv;*.flac;*.aac"/>
    <!-- 数据库文件名 -->
    <add key="DatabaseFile" value="MediaVault.db"/>
    <!-- 自动刷新间隔（秒） -->
    <add key="AutoRefreshInterval" value="30"/>
  </appSettings>
  <connectionStrings>
    <!-- SQLite连接字符串 -->
    <add name="SQLiteConnection" connectionString="Data Source=MediaVault.db;Version=3;"/>
  </connectionStrings>
</configuration>
